#!/usr/bin/env bash
# Output the remote slug (owner-repo) for the current git repo.
# Used by SKILL.md files to derive project-specific paths in ~/.gstack/projects/.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
if [ -x "$ROOT/bin/gstack-project-identity" ]; then
  eval "$("$ROOT/bin/gstack-project-identity" 2>/dev/null || true)"
fi
if [ -n "${GSTACK_REPO_SLUG:-}" ]; then
  echo "$GSTACK_REPO_SLUG"
else
  basename "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
fi
